{
  "expo": {
    "name": "StreakBoard",
    "slug": "streako",
    "version": "1.1.0",
    "scheme": "streakboard",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/App_icon.png",
    "splash": {
      "image": "./assets/App_splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.abhinikesh.streakboard",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.abhinikesh.streakboard",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0d1a"
      },
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "streakboard"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#7c3aed",
          "defaultChannel": "default"
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "StreakSmall",
              "label": "StreakBoard – Small",
              "description": "Current streak and today's habit progress",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000,
              "widgetFeatures": ["reconfigurable"]
            },
            {
              "name": "StreakMedium",
              "label": "StreakBoard",
              "description": "Streak, progress, and today's habit list",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000,
              "widgetFeatures": ["reconfigurable"]
            }
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "38630291-cf31-48aa-9431-1ad2adfe778e"
      }
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "owner": "abhinikeshkumar"
  }
}
